# Required at compile time (Rust env!() macros)
OUBLI_MAINNET_RPC_URL=https://your-mainnet-rpc-endpoint
OUBLI_SEPOLIA_RPC_URL=https://your-sepolia-rpc-endpoint

# Optional at compile time (Rust option_env!() macros)
OUBLI_MAINNET_PAYMASTER_API_KEY=your-mainnet-avnu-api-key
OUBLI_SEPOLIA_PAYMASTER_API_KEY=your-sepolia-avnu-api-key

# Required for Android release signing
OUBLI_KEYSTORE_PASSWORD=your-keystore-password
