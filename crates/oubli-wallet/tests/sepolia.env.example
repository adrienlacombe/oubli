## Sepolia on-chain test configuration for `oubli-wallet`
##
## Usage:
##   1. Copy this file:  cp sepolia.env.example sepolia.env
##   2. Fill in your secrets below.
##   3. Source it:
##        set -a && . crates/oubli-wallet/tests/sepolia.env && set +a
##        cargo test -p oubli-wallet --test integration -- --ignored --nocapture
##
## NOTE: All hex values must include the `0x` prefix.

# Starknet RPC endpoint (Sepolia) — get one from Chainstack, Alchemy, etc.
OUBLI_RPC_URL=

# AVNU paymaster API key — get one from https://avnu.fi
OUBLI_AVNU_PAYMASTER_API_KEY=

# Starknet chain id (Sepolia)
OUBLI_CHAIN_ID=SN_SEPOLIA

# Tongo contract address (encrypted BTC wrapper)
OUBLI_TONGO_CONTRACT=0x0408163bfcfc2d76f34b444cb55e09dace5905cf84c0884e4637c2c0f06ab6ed

# Underlying ERC-20 token contract (e.g. STRK / test token)
OUBLI_TOKEN_CONTRACT=0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d

# OZ account class hash v0.4.0
OUBLI_ACCOUNT_CLASS_HASH=0x036078334509b514626504edc9fb252328d1a240e4e948bef8d0c08dff45927f

# AVNU Paymaster URL (gasfree mode)
OUBLI_PAYMASTER_URL=https://sepolia.paymaster.avnu.fi

# Faucet mnemonic — this is the ONLY account that must hold STRK on Sepolia.
# All Sepolia tests generate fresh mnemonics and use this faucet to seed them with STRK.
OUBLI_TEST_MNEMONIC_A=
