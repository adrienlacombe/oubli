## Mainnet on-chain test configuration for `oubli-wallet`
##
## Usage:
##   1. Copy this file:  cp mainnet.env.example mainnet.env
##   2. Fill in your secrets below.
##   3. Source it:
##        set -a && . crates/oubli-wallet/tests/mainnet.env && set +a
##        cargo test -p oubli-wallet --test mainnet_full_flow -- --ignored --nocapture
##
## NOTE: All hex values must include the `0x` prefix.
## WARNING: This uses REAL WBTC on Starknet mainnet!

# Starknet RPC endpoint (mainnet) — get one from Dwellir, Alchemy, etc.
OUBLI_RPC_URL=

# AVNU paymaster API key
OUBLI_AVNU_PAYMASTER_API_KEY=

# Starknet chain id (mainnet)
OUBLI_CHAIN_ID=SN_MAIN

# Tongo contract address (mainnet, WBTC)
OUBLI_TONGO_CONTRACT=0x012ddbba903d9a22d3169b59c3de21affc1557d2d61b91646dfccd69b79b7120

# Underlying ERC-20 token contract (WBTC on Starknet)
OUBLI_TOKEN_CONTRACT=0x03fe2b97c1fd336e750087d68b9b867997fd64a2661ff3ca5a7c771641e8e7ac

# ArgentX v0.4 account class hash used by wallet + paymaster flows
OUBLI_ACCOUNT_CLASS_HASH=0x036078334509b514626504edc9fb252328d1a240e4e948bef8d0c08dff45927f

# AVNU Paymaster URL (mainnet)
OUBLI_PAYMASTER_URL=https://starknet.paymaster.avnu.fi

# Faucet mnemonic — pre-funded account that distributes WBTC to test wallets.
OUBLI_TEST_MNEMONIC_A=
